          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate Unique Quotation ID" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// Generate unique quotation ID using timestamp
long timestamp = System.currentTimeMillis()
String uniqueId = &quot;QT_&quot; + timestamp
vars.put(&quot;UNIQUE_QUOTATION_ID&quot;, uniqueId)
log.info(&quot;Generated unique quotation ID: &quot; + uniqueId)
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
