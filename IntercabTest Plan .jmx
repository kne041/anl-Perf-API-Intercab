        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set Corporate Group Per User" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
def threadNum = ctx.getThreadNum()
if (threadNum == 0) {
    vars.put(&quot;corporateGroupId&quot;, &quot;6813&quot;)
    vars.put(&quot;corporateGroupName&quot;, &quot;Performancetesting8&quot;)
} else if (threadNum == 1) {
    vars.put(&quot;corporateGroupId&quot;, &quot;6814&quot;)
    vars.put(&quot;corporateGroupName&quot;, &quot;Performancetesting9&quot;)
} else if (threadNum == 2) {
    vars.put(&quot;corporateGroupId&quot;, &quot;6815&quot;)
    vars.put(&quot;corporateGroupName&quot;, &quot;Performancetesting10&quot;)
} else if (threadNum == 3) {
    vars.put(&quot;corporateGroupId&quot;, &quot;6816&quot;)
    vars.put(&quot;corporateGroupName&quot;, &quot;Performancetesting11&quot;)
} else {
    vars.put(&quot;corporateGroupId&quot;, &quot;6817&quot;)
    vars.put(&quot;corporateGroupName&quot;, &quot;Performancetesting12&quot;)
}
          </stringProp>
        </JSR223PreProcessor>
