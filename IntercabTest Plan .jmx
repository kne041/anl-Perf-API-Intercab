          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generator_Calendar" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Calendar;

Calendar calTomorrow = Calendar.getInstance();
calTomorrow.add(Calendar.DAY_OF_MONTH, 3);
SimpleDateFormat sdfTomorrow = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);
String dataTomorrow = sdfTomorrow.format(calTomorrow.getTime());
vars.put(&quot;dataTomorrow&quot;, dataTomorrow);

Calendar calAfterTomorrow = Calendar.getInstance();
calAfterTomorrow.add(Calendar.DAY_OF_MONTH, 4);
SimpleDateFormat sdfAfterTomorrow = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);
String dataAfterTomorrow = sdfAfterTomorrow.format(calAfterTomorrow.getTime());
vars.put(&quot;dataAfterTomorrow&quot;, dataAfterTomorrow);
</stringProp>
            <stringProp name="scriptLanguage">java</stringProp>
          </JSR223PreProcessor>
