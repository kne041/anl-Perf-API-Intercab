          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extractor IDs" enabled="true">
            <stringProp name="JSONPostProcessor.referenceNames">costingID</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.data.id</stringProp>
            <stringProp name="JSONPostProcessor.match_numbers"></stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

try {
    // Retrieve response data
    def response = prev.getResponseDataAsString()
    
    // Parse JSON response
    def json = new JsonSlurper().parseText(response)

    // Extract IDs if &apos;data&apos; field is present
    if (json.data) {
        def ids = json.data.collect { it.id }
        log.info(&quot;Extracted IDs: ${ids}&quot;)
        // Convert IDs to a comma-separated string
        def idsString = ids.join(&apos;, &apos;)
        
        // Store the IDs in a JMeter variable
        vars.put(&quot;all_ids&quot;, idsString)
    } else {
        log.warn(&quot;Data field not found in the response.&quot;)
    }

    // Retrieve the all_ids variable and convert it to a list of integers
    def allIdsString = vars.get(&quot;all_ids&quot;)
    if (allIdsString) {
        def allIdsList = allIdsString.split(&apos;, &apos;).collect { it.toInteger() }
        
        // Find the maximum ID value
        def maxId = allIdsList.max()
        
        // Store the maximum ID in a JMeter variable
        vars.put(&quot;maxId&quot;, maxId.toString())
        
        // Log the result
        log.info(&quot;Max ID: ${idPaPa}&quot;)
    } else {
        log.warn(&quot;No IDs found in &apos;all_ids&apos;.&quot;)
    }
} catch (Exception e) {
    log.error(&quot;Error extracting IDs: ${e.message}&quot;)
}</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
